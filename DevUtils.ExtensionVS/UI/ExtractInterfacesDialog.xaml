<platform:DialogWindow
    x:Class="DevUtils.ExtensionVS.UI.ExtractInterfacesDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:platform="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
    xmlns:local="clr-namespace:DevUtils.ExtensionVS.UI"
    Title="Extract Interfaces in Batch"
    Width="600" Height="560"
    MinWidth="480" MinHeight="440"
    WindowStartupLocation="CenterOwner"
    HasMaximizeButton="False"
    HasMinimizeButton="False">

    <Grid Margin="12,10,12,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar row -->
        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Select classes to extract:"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" Content="Select All"   Width="82" Padding="4,2" Click="OnSelectAll"/>
            <Button Grid.Column="3" Content="Deselect All" Width="82" Padding="4,2" Click="OnDeselectAll"/>
        </Grid>

        <!-- Class tree -->
        <Border Grid.Row="1"
                Margin="0,0,0,8"
                BorderThickness="1"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
            <TreeView ItemsSource="{Binding RootNodes}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True"/>
                    </Style>
                </TreeView.ItemContainerStyle>
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate DataType="{x:Type local:ClassTreeNode}"
                                              ItemsSource="{Binding Children}">
                        <StackPanel Orientation="Horizontal" Margin="0,1,4,1">
                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                      IsThreeState="True"
                                      VerticalAlignment="Center"
                                      Margin="0,0,4,0"
                                      Click="OnNodeCheckBoxClick"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>

        <!-- Output settings -->
        <GroupBox Grid.Row="2" Header="Output Settings" Margin="0,0,0,8">
            <Grid Margin="8,6,8,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="72"/>
                </Grid.ColumnDefinitions>

                <!-- Namespace -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Namespace:"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                         Text="{Binding NamespaceText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Leave empty to use each class's own namespace"/>

                <!-- Place next to source -->
                <CheckBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                          IsChecked="{Binding UseSourceLocation}"
                          Content="Place each interface file next to its source class (default)"/>

                <!-- Output folder -->
                <TextBlock Grid.Row="4" Grid.Column="0"
                           Text="Output folder:"
                           VerticalAlignment="Center"
                           Opacity="{Binding OutputFieldOpacity}"/>
                <TextBox Grid.Row="4" Grid.Column="1"
                         Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsOutputFolderEnabled}"/>
                <Button Grid.Row="4" Grid.Column="3"
                        Content="Browse..."
                        IsEnabled="{Binding IsOutputFolderEnabled}"
                        Click="OnBrowseOutputFolder"/>
            </Grid>
        </GroupBox>

        <!-- Dialog buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel" Width="75" Margin="0,0,6,0" IsCancel="True" Click="OnCancel"/>
            <Button Content="Extract" Width="75" IsDefault="True" Click="OnExtract"/>
        </StackPanel>
    </Grid>
</platform:DialogWindow>
